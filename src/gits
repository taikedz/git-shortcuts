#!/usr/bin/env bash

set -euo pipefail

GITS_software_version="1.5.3"
GITS_software_version_message="(C) Tai Kedzierski, GPLv3. https://github.com/taikedz/git-shortcuts"

#%include help.sh

#%include std/autohelp.sh
#%include std/out.sh
#%include std/syntax-extensions.sh
#%include std/debug.sh

#%include modules.sh

gits:main() {

    local action

    action="${1:-}"; shift || :

    [[ -n "$action" ]] || {
        gits:status:short
        echo
        out:info "${CBBLU}(see also: gits fs)"
        exit
    }

    case "$action" in
    native|ntv) # An explicit passthru, in case we do not want the git-shortcuts built-in handler to process the command
        gits:passthru:run "$@"
        ;;
    --help)
        autohelp:print
        exit 0
        ;;
    --version)
        out:info "Git Shortcuts @ $GITS_software_version"
        out:info "${CGRN}$GITS_software_version_message"
        ;;
    -mm)
        gits:commit "$action" "$@"
        ;;
    help)
        autohelp:print help
        ;;

    # Keep the rest alphabeticl please:

    biggest)
        gits:biggest "$@"
        ;;
    branch)
        gits:branch:_dispatch "$@"
        ;;
    clean)
        gits:clean "$@"
        ;;
    clone)
        gits:clone:_dispatch "$@"
        ;;
    co|checkout)
        gits:checkout "$@"
        ;;
    diff)
        gits:diff "$@"
        ;;
    fp)
        gits:fp "$@"
        ;;
    fs)
        gits:status:fetch "$@"
        ;;
    gc)
        gits:gc-full "$@"
        ;;
    log)
        gits:log "$@"
        ;;
    master)
        gits:master "$@"
        ;;
    profile)
        gits:profiles:_dispatch "$@"
        ;;
    pull)
        gits:pull:_dispatch "$@"
        ;;
    push)
        gits:push "$@"
        ;;
    remote)
        gits:remote:_dispatch "$@"
        ;;
    status)
        gits:status:short "$@"
        ;;
    version)
        gits:version:_dispatch "$@"
        ;;
    *)
        if gits:passthru:check "$action"; then
            gits:passthru:run "$action" "$@"
        else
            gits:diff "$action" "$@" # Assume "$action" is also a file to be diffed
        fi
        ;;
    esac
}

gits:main "$@"
